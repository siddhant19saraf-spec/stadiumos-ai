# =============================================================================
# StadiumOS AI — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.
# =============================================================================

# --- AI Provider Keys (at least one required for production AI features) ---

# OpenAI API key for AI Copilot features
# Get yours at: https://platform.openai.com/api-keys
NEXT_PUBLIC_OPENAI_API_KEY=

# Google Gemini API key (alternative AI provider)
# Get yours at: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# --- Backend API ---

# URL of the StadiumOS backend API
# Default: http://localhost:8000 (development)
# Production: https://your-backend.vercel.app or your deployed backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Authentication ---

# Secret key for JWT signing — generate with: openssl rand -base64 32
# Required for authentication features
AUTH_SECRET=

# --- Logging ---

# Logging verbosity level
# Values: debug | info | warn | error
# Default: info
NEXT_PUBLIC_LOG_LEVEL=info
