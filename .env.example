# ─── Application ──────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
APP_NAME=StadiumOS AI

# ─── Authentication ──────────────────────────────────────
AUTH_SECRET=change-me-to-a-random-64-char-string
AUTH_URL=http://localhost:3000
JWT_SECRET=change-me-to-another-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://stadiumos:stadiumos@localhost:5432/stadiumos
DATABASE_URL_SYNC=postgresql://stadiumos:stadiumos@localhost:5432/stadiumos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50

# ─── AI Providers ─────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_TOKENS=4096
GEMINI_TEMPERATURE=0.2

AI_PROVIDER_PRIMARY=openai
AI_PROVIDER_FALLBACK=gemini
AI_RATE_LIMIT_REQUESTS_PER_MINUTE=60
AI_CACHE_TTL_SECONDS=300

# ─── Security ────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_MINUTE_ADMIN=1000
BCRYPT_ROUNDS=12

# ─── External APIs ───────────────────────────────────────
WEATHER_API_KEY=
WEATHER_API_BASE_URL=https://api.weather.com/v1
TRAFFIC_API_KEY=
TRAFFIC_API_BASE_URL=https://api.traffic.com/v1

# ─── Monitoring ──────────────────────────────────────────
LOG_LEVEL=DEBUG
SENTRY_DSN=
ENABLE_TELEMETRY=false

# ─── Deployment ──────────────────────────────────────────
VERCEL_URL=
DOCKER_IMAGE_TAG=latest
